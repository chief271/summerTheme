{%- style -%}
.instagram-feed {
width: 90%;
max-width: 1536px;
margin: 5rem auto;
position: relative;
overflow: hidden;
}

.instagram-header {
text-align: center;
margin-bottom: 3rem;
}

.instagram-title {
font-size: 2.5rem;
margin-bottom: 1rem;
color: {{ section.settings.heading_color }};
}

.instagram-subtitle {
font-size: 1.1rem;
color: {{ section.settings.subtitle_color }};
max-width: 600px;
margin: 0 auto 2rem;
}

.instagram-handle {
display: inline-block;
color: #E1306C;
font-weight: 600;
text-decoration: none;
margin-top: 1rem;
}

.instagram-track {
display: flex;
gap: 1.5rem;
padding: 1rem 0;
animation: scroll {{ section.settings.speed | times: 10 }}s linear infinite;
width: max-content;
}

@keyframes scroll {
0% {
transform: translateX(0);
}
100% {
transform: translateX(calc(-280px * {{ section.blocks.size }} / 2));
}
}

.instagram-card {
position: relative;
width: 280px;
height: 280px;
border-radius: 12px;
overflow: hidden;
flex-shrink: 0;
transition: transform 0.3s ease;
}

.instagram-card:hover {
transform: translateY(-5px);
}

.instagram-image {
width: 100%;
height: 100%;
object-fit: cover;
display: block;
}

.instagram-overlay {
position: absolute;
top: 0;
left: 0;
right: 0;
bottom: 0;
background: rgba(0, 0, 0, 0.3);
display: flex;
align-items: center;
justify-content: center;
opacity: 0;
transition: opacity 0.3s ease;
}

.instagram-card:hover .instagram-overlay {
opacity: 1;
}

.instagram-icon {
width: 2.5rem;
height: 2.5rem;
fill: white;
}

.instagram-mask {
position: absolute;
top: 0;
left: 0;
right: 0;
bottom: 0;
background: rgba(225, 48, 108, 0.8);
display: flex;
align-items: center;
justify-content: center;
flex-direction: column;
color: white;
text-align: center;
padding: 1rem;
}

.instagram-logo {
font-size: 2.5rem;
margin-bottom: 0.5rem;
}

.instagram-follow {
font-size: 0.9rem;
margin-top: 0.5rem;
}

@media (max-width: 768px) {
.instagram-track {
gap: 1rem;
}

.instagram-card {
width: 240px;
height: 240px;
}
}
{%- endstyle -%}

<div id="{{section.id}}" class=" instagram-feed container">
    <div class="instagram-header">
        <h2 class="instagram-title">{{ section.settings.heading }}</h2>
        {% if section.settings.subtitle != blank %}
        <p class="instagram-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        <a href="{{ section.settings.instagram_url }}" class="instagram-handle" target="_blank" rel="noopener">
            {{ section.settings.instagram_handle }}
        </a>
    </div>

    <div class="instagram-carousel">
        <div class="instagram-track">
            {% for block in section.blocks %}
            {% assign random_number = "now" | date: "%N" | modulo: section.blocks.size | plus: 1 %}
            <div class="instagram-card" {{ block.shopify_attributes }}>
                {% if block.settings.image != blank %}
                {{ block.settings.image | image_url: width: 600 | image_tag:
                class: 'instagram-image',
                loading: 'lazy',
                width: 600,
                height: 600,
                alt: block.settings.alt | escape
                }}
                {% else %}
                {{ 'image' | placeholder_svg_tag: 'instagram-image' }}
                {% endif %}

                <a href="{{ section.settings.instagram_url }}" class="instagram-overlay" target="_blank" rel="noopener">
                    <svg class="instagram-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
