{{ 'collection-showcase.css' | asset_url | stylesheet_tag }}

{% assign collection = section.settings.collection %}
{% assign display_image = section.settings.custom_image | default: collection.image %}

<div class="showcase page-width">
    <div class="showcase__left" {% if display_image
        %}style="background-image: url('{{ display_image | image_url: width: 1200 }}');" {% endif %}>
        <div class="showcase__left_overlay"></div>
        <div class="showcase__left_content">
            {% if section.settings.heading != blank %}
            <h2 class="showcase__heading">{{ section.settings.heading }}</h2>
            {% endif %}
            {% if section.settings.subtext != blank %}
            <div class="showcase__subtext">{{ section.settings.subtext }}</div>
            {% endif %}
            {% if collection and section.settings.show_button %}
            <a href="{{ collection.url }}" class="showcase__button">
                {{ section.settings.button_label | default: 'Shop Collection' }}
            </a>
            {% endif %}
        </div>
    </div>

    <div class="showcase__right">
        {% if collection %}
        <div class="showcase__grid" style="--cols: {{ section.settings.columns }};">
            {% assign product_limit = section.settings.product_count %}
            {% for product in collection.products limit: product_limit %}
            <a href="{{ product.url }}" class="showcase__product">
                <div class="showcase__product_image">
                    {% if product.featured_image %}
                    <img src="{{ product.featured_image | image_url: width: 500 }}"
                        alt="{{ product.featured_image.alt | escape }}" loading="lazy" width="500"
                        height="{{ 500 | divided_by: product.featured_image.aspect_ratio }}">
                    {% endif %}
                </div>
                <div class="showcase__product_title">{{ product.title }}</div>
                <div class="showcase__product_price">{{ product.price | money }}</div>
            </a>
            {% else %}
            <div class="showcase__empty">No products in this collection yet.</div>
            {% endfor %}
        </div>
        {% else %}
        <div class="showcase__empty">Select a collection to show products.</div>
        {% endif %}
    </div>
</div>

{% schema %}
{
"name": "Collection Showcase",
"settings": [
{
"type": "collection",
"id": "collection",
"label": "Collection"
},
{
"type": "image_picker",
"id": "custom_image",
"label": "Custom image (optional, overrides collection image)"
},
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Shop the Collection"
},
{
"type": "textarea",
"id": "subtext",
"label": "Subtext"
},
{
"type": "checkbox",
"id": "show_button",
"label": "Show button",
"default": true
},
{
"type": "text",
"id": "button_label",
"label": "Button label",
"default": "Shop Collection"
},
{
"type": "range",
"id": "product_count",
"label": "Number of products to show",
"min": 2,
"max": 8,
"step": 2,
"default": 4
},
{
"type": "range",
"id": "columns",
"label": "Columns on right side",
"min": 1,
"max": 3,
"step": 1,
"default": 2
}
],
"presets": [
{
"name": "Collection Showcase"
}
]
}
{% endschema %}