<script>

    (function () {

        const section =
            document.getElementById(
                'lookbook-{{ section.id }}'
            );


        if (!section) return;


        const hotspots =
            section.querySelectorAll(
                '.lookbook-hotspot'
            );


        const cards =
            section.querySelectorAll(
                '.lookbook-product-card'
            );


        function closeAll() {

            cards.forEach(function (card) {

                card.classList.remove(
                    'is-active'
                );

            });

            hotspots.forEach(function (hotspot) {

                hotspot.classList.remove(
                    'is-active'
                );

            });

        }


        function positionCard(
            card,
            hotspot
        ) {

            const sectionRect =
                section.getBoundingClientRect();


            const hotspotRect =
                hotspot.getBoundingClientRect();


            const cardWidth =
                220;


            const cardHeight =
                270;


            const gap =
                16;


            let left =
                hotspotRect.left -
                sectionRect.left +
                hotspotRect.width +
                gap;


            let top =
                hotspotRect.top -
                sectionRect.top -
                cardHeight / 2;


            if (
                left + cardWidth >
                sectionRect.width - 10
            ) {

                left =
                    hotspotRect.left -
                    sectionRect.left -
                    cardWidth -
                    gap;

            }


            top =
                Math.max(
                    10,

                    Math.min(
                        top,

                        sectionRect.height -
                        cardHeight -
                        10

                    )

                );


            card.style.left =
                left + 'px';


            card.style.top =
                top + 'px';

        }


        hotspots.forEach(function (hotspot) {

            hotspot.addEventListener(
                'click',
                function (event) {

                    event.stopPropagation();


                    const index =
                        this.dataset.index;


                    const card =
                        document.getElementById(
                            'product-card-{{ section.id }}-' +
                            index
                        );


                    if (!card) return;


                    const isActive =
                        card.classList.contains(
                            'is-active'
                        );


                    closeAll();


                    if (!isActive) {

                        positionCard(
                            card,
                            this
                        );


                        card.classList.add(
                            'is-active'
                        );


                        this.classList.add(
                            'is-active'
                        );

                    }

                }

            );

        });


        cards.forEach(function (card) {

            const closeButton =
                card.querySelector(
                    '.lookbook-product-card__close'
                );


            closeButton.addEventListener(
                'click',
                function () {

                    closeAll();

                }

            );

        });


        document.addEventListener(
            'click',
            function (event) {

                if (
                    !section.contains(
                        event.target
                    )
                ) {

                    return;

                }


                if (
                    !event.target.closest(
                        '.lookbook-hotspot'
                    ) &&
                    !event.target.closest(
                        '.lookbook-product-card'
                    )
                ) {

                    closeAll();

                }

            }

        );


        window.addEventListener(
            'resize',
            function () {

                cards.forEach(function (card) {

                    card.classList.remove(
                        'is-active'
                    );

                });

            }

        );

    })();

</script>


