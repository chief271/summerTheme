{% if section.settings.desktop_image != blank %}

<section class="hero-section" id="lookbook-{{ section.id }}" class="lookbook-hero" style="
        --desktop-height: {{ section.settings.desktop_height }}px;
        --mobile-height: {{ section.settings.mobile_height }}px;
        --accent-color: {{ section.settings.accent_color }};
    ">

    <!-- IMAGE -->
    <picture class="lookbook-hero__media">

        {% if section.settings.mobile_image != blank %}

        <source media="(max-width: 950px)" srcset="{{ section.settings.mobile_image | image_url: width: 1600 }}">

        {% endif %}

        <img class="lookbook-hero__image" src="{{ section.settings.desktop_image | image_url: width: 3840 }}"
            alt="{{ section.settings.desktop_image.alt | escape }}" loading="eager">

    </picture>


    <!-- IMAGE OVERLAY -->
    <div class="lookbook-hero__overlay"></div>


    <!-- CONTENT -->
    <div class="lookbook-hero__content">

        {% if section.settings.eyebrow != blank %}

        <p class="lookbook-hero__eyebrow">
            {{ section.settings.eyebrow }}
        </p>

        {% endif %}


        {% if section.settings.heading != blank %}

        <h1 class="lookbook-hero__heading">
            {{ section.settings.heading }}
        </h1>

        {% endif %}


        {% if section.settings.button_label != blank %}

        <a href="{{ section.settings.button_link }}" class="lookbook-hero__button">
            {{ section.settings.button_label }}
        </a>

        {% endif %}

    </div>


    <!-- HOTSPOTS -->
    <div class="lookbook-hotspots">

        {% for i in (1..5) %}

        {% liquid

        assign product_key = 'point_' | append: i | append: '_product'

        assign desktop_x_key = 'point_' | append: i | append: '_desktop_x'
        assign desktop_y_key = 'point_' | append: i | append: '_desktop_y'

        assign mobile_x_key = 'point_' | append: i | append: '_mobile_x'
        assign mobile_y_key = 'point_' | append: i | append: '_mobile_y'

        assign product = section.settings[product_key]

        assign desktop_x = section.settings[desktop_x_key]
        assign desktop_y = section.settings[desktop_y_key]

        assign mobile_x = section.settings[mobile_x_key]
        assign mobile_y = section.settings[mobile_y_key]

        %}


        {% if product != blank %}

        <button type="button" class="lookbook-hotspot" data-index="{{ i }}" style="
                        --desktop-x: {{ desktop_x }}%;
                        --desktop-y: {{ desktop_y }}%;
                        --mobile-x: {{ mobile_x }}%;
                        --mobile-y: {{ mobile_y }}%;
                    " aria-label="View {{ product.title }}">

            <span class="lookbook-hotspot__pulse"></span>

            <span class="lookbook-hotspot__dot">

                <svg width="8" height="8" viewBox="0 0 8 8" fill="none" aria-hidden="true">
                    <path d="M4 0V8M0 4H8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" />
                </svg>

            </span>

        </button>


        <!-- PRODUCT CARD -->

        <div class="lookbook-product-card" id="product-card-{{ section.id }}-{{ i }}">

            <button type="button" class="lookbook-product-card__close" aria-label="Close product">
                ×
            </button>


            {% if product.featured_image != blank %}

            <a href="{{ product.url }}" class="lookbook-product-card__image">

                <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}"
                    loading="lazy">

            </a>

            {% endif %}


            <div class="lookbook-product-card__content">

                <h3>
                    {{ product.title }}
                </h3>


                <p>
                    {{ product.price | money }}
                </p>


                <a href="{{ product.url }}" class="lookbook-product-card__button">
                    View product
                </a>

            </div>

        </div>

        {% endif %}

        {% endfor %}

    </div>


    <div class="lookbook-backdrop"></div>

</section>


