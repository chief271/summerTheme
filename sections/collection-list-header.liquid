{{ 'collection-list-header.css' | asset_url | stylesheet_tag }}

<div class="page_header{% if section.settings.bg_image %} page_header--has-image{% endif %}" {% if
    section.settings.bg_image %}
    style="background-image: url('{{ section.settings.bg_image | image_url: width: 1600 }}');" {% endif %}>
    <div class="page_header__inner">
        {% if section.settings.heading != blank %}
        <h1 class="page_header__heading">{{ section.settings.heading }}</h1>
        {% endif %}

        {% if section.settings.subtext != blank %}
        <div class="page_header__subtext">{{ section.settings.subtext }}</div>
        {% endif %}
    </div>
</div>

{% schema %}
{
"name": "Collection List Header",
"settings": [
{
"type": "text",
"id": "heading",
"label": "Heading",
"default": "Shop by Category"
},
{
"type": "textarea",
"id": "subtext",
"label": "Subtext",
"default": "Browse our full range of collections."
},
{
"type": "image_picker",
"id": "bg_image",
"label": "Background image (optional)"
},
{
"type": "color",
"id": "bg_color",
"label": "Background color",
"default": "#f5f5f5"
},
{
"type": "color",
"id": "text_color",
"label": "Text color",
"default": "#111111"
}
],
"presets": [
{
"name": "Collection List Header"
}
]
}
{% endschema %}