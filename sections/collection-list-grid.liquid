{{ 'collection-list-grid.css' | asset_url | stylesheet_tag }}

<div class="collection_grid">
    {% for block in section.blocks %}
    {% assign collection = block.settings.collection %}
    <div class="collection_grid__item" {{ block.shopify_attributes }}>
        {% if collection %}
        <a href="{{ collection.url }}" class="collection_card">
            <div class="collection_card__image">
                {% if collection.image %}
                <img src="{{ collection.image | image_url: width: 600 }}" alt="{{ collection.image.alt | escape }}"
                    loading="lazy" width="600" height="{{ 600 | divided_by: collection.image.aspect_ratio }}">
                {% else %}
                <div class="collection_card__placeholder"></div>
                {% endif %}
            </div>

            <div class="collection_card__info">
                <div class="collection_card__title">{{ collection.title }}</div>
                {% if block.settings.show_count %}
                <div class="collection_card__count">{{ collection.products_count }} items</div>
                {% endif %}
            </div>
        </a>
        {% else %}
        <div class="collection_card collection_card--placeholder">
            <div class="collection_card__title">Select a collection</div>
        </div>
        {% endif %}
    </div>
    {% endfor %}
</div>

{% schema %}
{
"name": "Collection List Grid",
"settings": [
{
"type": "range",
"id": "columns_desktop",
"label": "Columns on desktop",
"min": 2,
"max": 5,
"step": 1,
"default": 4
},
{
"type": "select",
"id": "columns_mobile",
"label": "Columns on mobile",
"options": [
{ "value": "1", "label": "1" },
{ "value": "2", "label": "2" }
],
"default": "2"
}
],
"blocks": [
{
"name": "Collection",
"type": "collection",
"settings": [
{
"type": "collection",
"id": "collection",
"label": "Collection"
},
{
"type": "checkbox",
"id": "show_count",
"label": "Show product count",
"default": true
}
]
}
],
"presets": [
{
"name": "Collection List Grid",
"blocks": [
{ "type": "collection" },
{ "type": "collection" },
{ "type": "collection" },
{ "type": "collection" }
]
}
]
}
{% endschema %}